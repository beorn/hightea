{
  "name": "@silvery/ag-react",
  "version": "0.17.3",
  "description": "Core React reconciler and runtime for silvery (internal — use silvery instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/ag-react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./reconciler": "./src/reconciler/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./components": "./src/components/index.ts",
    "./providers": "./src/providers/index.ts",
    "./contexts": "./src/contexts/index.ts",
    "./ui": "./src/ui/index.ts",
    "./ui/animation": "./src/ui/animation.ts",
    "./ui/components": "./src/ui/components.ts",
    "./ui/components/*": "./src/ui/components/*.tsx",
    "./ui/images": "./src/ui/images.ts",
    "./ui/types": "./src/ui/types.ts",
    "./ui/cli": "./src/ui/cli/index.ts",
    "./ui/cli/*": "./src/ui/cli/*.ts",
    "./ui/hooks/*": "./src/ui/hooks/*.ts",
    "./ui/react": "./src/ui/react/index.ts",
    "./ui/react/*": "./src/ui/react/*.tsx",
    "./ui/ansi": "./src/ui/ansi/index.ts",
    "./ui/ansi/*": "./src/ui/ansi/*.ts",
    "./ui/image/*": "./src/ui/image/*.ts",
    "./ui/input/*": "./src/ui/input/*.ts",
    "./ui/progress": "./src/ui/progress/index.ts",
    "./ui/progress/*": "./src/ui/progress/*.ts",
    "./ui/display/*": "./src/ui/display/*.ts",
    "./ui/wrappers/*": "./src/ui/wrappers/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./providers/*": "./src/providers/*.tsx",
    "./contexts/*": "./src/contexts/*.ts",
    "./reconciler/*": "./src/reconciler/*.ts",
    "./render": "./src/render.tsx",
    "./render-string": "./src/render-string.tsx",
    "./error-boundary": "./src/error-boundary.tsx",
    "./ThemeProvider": "./src/ThemeProvider.tsx",
    "./ReactiveThemeProvider": "./src/ReactiveThemeProvider.tsx",
    "./*": ["./src/*.ts", "./src/*.tsx"],
    "./*.ts": "./src/*.ts",
    "./*.tsx": "./src/*.tsx"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ag": "0.17.3",
    "@silvery/headless": "0.17.3",
    "@silvery/theme": "0.17.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  },
  "private": true
}
