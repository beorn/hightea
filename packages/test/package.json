{
  "name": "@silvery/test",
  "version": "0.4.1",
  "description": "Testing utilities for silvery \u2014 virtual renderer, locators, assertions",
  "license": "MIT",
  "author": "Bj\u00f8rn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/test"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@silvery/ag": "workspace:*",
    "@silvery/ag-react": "workspace:*",
    "@silvery/ag-term": "workspace:*",
    "@silvery/tea": "workspace:*"
  }
}