{
  "name": "@silvery/theme",
  "version": "0.17.3",
  "private": true,
  "description": "Theming system with semantic color tokens for silvery (internal \u2014 use silvery/theme instead)",
  "license": "MIT",
  "author": "Bj\u00f8rn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./*.tsx": "./src/*.tsx"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./ThemeContext": {
        "types": "./dist/ThemeContext.d.mts",
        "import": "./dist/ThemeContext.mjs"
      },
      "./detect": {
        "types": "./dist/detect.d.mts",
        "import": "./dist/detect.mjs"
      },
      "./palettes": {
        "types": "./dist/palettes.d.mts",
        "import": "./dist/palettes.mjs"
      },
      "./resolve": {
        "types": "./dist/resolve.d.mts",
        "import": "./dist/resolve.mjs"
      },
      "./state": {
        "types": "./dist/state.d.mts",
        "import": "./dist/state.mjs"
      },
      "./theme": {
        "types": "./dist/theme.d.mts",
        "import": "./dist/theme.mjs"
      },
      "./types": {
        "types": "./dist/types.d.mts",
        "import": "./dist/types.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@silvery/ansi": "0.17.3",
    "@silvery/color": "0.17.3"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.ts",
      "src/ThemeContext.tsx",
      "src/detect.ts",
      "src/palettes/index.ts",
      "src/resolve.ts",
      "src/state.ts",
      "src/theme.ts",
      "src/types.ts"
    ],
    "format": "esm"
  }
}
