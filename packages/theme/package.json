{
  "name": "@silvery/theme",
  "version": "0.5.1",
  "description": "Theming system with semantic color tokens for silvery (internal — use silvery/theme instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ansi": "0.3.4",
    "@silvery/color": "0.1.2"
  },
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  }
}
