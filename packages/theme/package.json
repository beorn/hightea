{
  "name": "@silvery/theme",
  "version": "0.17.3",
  "description": "Theming system with semantic color tokens for silvery (internal — use silvery/theme instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ThemeContext": "./src/ThemeContext.tsx",
    "./detect": "./src/detect.ts",
    "./palettes": "./src/palettes/index.ts",
    "./resolve": "./src/resolve.ts",
    "./state": "./src/state.ts",
    "./theme": "./src/theme.ts",
    "./types": "./src/types.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./ThemeContext": {
        "types": "./dist/ThemeContext.d.mts",
        "import": "./dist/ThemeContext.mjs"
      },
      "./detect": {
        "types": "./dist/detect.d.mts",
        "import": "./dist/detect.mjs"
      },
      "./palettes": {
        "types": "./dist/palettes.d.mts",
        "import": "./dist/palettes.mjs"
      },
      "./resolve": {
        "types": "./dist/resolve.d.mts",
        "import": "./dist/resolve.mjs"
      },
      "./state": {
        "types": "./dist/state.d.mts",
        "import": "./dist/state.mjs"
      },
      "./theme": {
        "types": "./dist/theme.d.mts",
        "import": "./dist/theme.mjs"
      },
      "./types": {
        "types": "./dist/types.d.mts",
        "import": "./dist/types.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ansi": "0.17.3",
    "@silvery/color": "0.17.3"
  },
  "tsdown": {
    "entry": [
      "src/index.ts",
      "src/ThemeContext.tsx",
      "src/detect.ts",
      "src/palettes/index.ts",
      "src/resolve.ts",
      "src/state.ts",
      "src/theme.ts",
      "src/types.ts"
    ],
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  },
  "private": true
}
