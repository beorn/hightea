        "types": "./dist/text-cursor.d.mts",
        "import": "./dist/text-cursor.mjs"
      },
      "./text-decorations": {
        "types": "./dist/text-decorations.d.mts",
        "import": "./dist/text-decorations.mjs"
      },
      "./text-ops": {
        "types": "./dist/text-ops.d.mts",
        "import": "./dist/text-ops.mjs"
      },
      "./types": {
        "types": "./dist/types.d.mts",
        "import": "./dist/types.mjs"
      },
      "./with-app": {
        "types": "./dist/with-app.d.mts",
        "import": "./dist/with-app.mjs"
