        "types": "./dist/internal/input-router.d.mts",
        "import": "./dist/internal/input-router.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ag": "0.17.3",
    "@silvery/ag-react": "0.17.3",
    "@silvery/ag-term": "0.17.3",
    "@silvery/commands": "0.17.3",
    "@silvery/headless": "0.17.3",
