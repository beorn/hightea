      "src/streams/index.ts",
      "src/tea/index.ts",
      "src/text-cursor.ts",
      "src/text-decorations.ts",
      "src/text-ops.ts",
      "src/types.ts",
      "src/with-app.ts",
      "src/with-render.ts",
      "src/internal/capabilities.ts",
      "src/internal/capability-registry.ts",
      "src/internal/input-router.ts"
