{
  "name": "@silvery/ag-term",
  "version": "0.17.3",
  "description": "Terminal rendering target for silvery (internal — use silvery instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/ag-term"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./ansi": "./src/ansi/index.ts",
    "./features": "./src/features/index.ts",
    "./plugins": "./src/plugins/index.ts",
    "./pipeline": "./src/pipeline/index.ts",
    "./pipeline/*": "./src/pipeline/*.ts",
    "./ansi/*": "./src/ansi/*.ts",
    "./features/*": "./src/features/*.ts",
    "./plugins/*": "./src/plugins/*.ts",
    "./runtime/*": "./src/runtime/*.ts",
    "./adapters/*": "./src/adapters/*.ts",
    "./xterm/*": "./src/xterm/*.ts",
    "./*": "./src/*.ts",
    "./*.ts": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ag": "0.17.3",
    "@silvery/ag-react": "0.17.3",
    "@silvery/ansi": "0.17.3",
    "@silvery/create": "0.17.3",
    "@silvery/headless": "0.17.3",
    "@silvery/signals": "0.17.3",
    "@silvery/test": "0.17.3",
    "@silvery/theme": "0.17.3",
    "flexily": "0.5.2"
  },
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  },
  "private": true
}
