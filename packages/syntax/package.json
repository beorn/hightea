{
  "name": "@silvery/syntax",
  "version": "0.21.0",
  "description": "Shiki-backed syntax highlighting for silvery — ANSI tokens for terminal rendering and styled spans for web/canvas targets.",
  "keywords": [
    "ansi",
    "code",
    "highlight",
    "shiki",
    "syntax",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/syntax"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "shiki": "^2.5.0"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
