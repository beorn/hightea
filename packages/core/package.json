{
  "name": "@hightea/core",
  "version": "0.1.0",
  "description": "TEA runtime, React reconciler, store, and effect system — portable core of hightea",
  "keywords": [
    "components",
    "effects",
    "elm-architecture",
    "react",
    "reconciler",
    "state-machine",
    "store",
    "tea",
    "tui"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./store": {
      "types": "../../src/store/index.ts",
      "import": "../../src/store/index.ts"
    },
    "./tea": {
      "types": "../../src/tea/index.ts",
      "import": "../../src/tea/index.ts"
    },
    "./react": {
      "types": "../../src/react/index.ts",
      "import": "../../src/react/index.ts"
    }
  },
  "dependencies": {
    "react-reconciler": "^0.33.0",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
